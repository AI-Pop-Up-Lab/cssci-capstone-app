{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Backend: FastAPI",
      "type": "debugpy",
      "request": "launch",
      "python": "${workspaceFolder}/env/bin/python",
      "module": "uvicorn",
      "cwd": "${workspaceFolder}/ai-popup-lab-backend",
      "args": [
        "main:app",
        "--reload",
        "--host",
        "127.0.0.1",
        "--port",
        "8000"
      ],
      "jinja": true,
      "console": "integratedTerminal"
    },
    {
      "name": "Frontend: React",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm start",
      "cwd": "${workspaceFolder}/ai-popup-lab-application"
    }
  ],
  "compounds": [
    {
      "name": "Full Stack: Frontend + Backend",
      "configurations": [
        "Backend: FastAPI",
        "Frontend: React"
      ],
      "stopAll": true
    }
  ]
}
